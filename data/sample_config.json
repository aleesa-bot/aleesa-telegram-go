{
    // Настройки коммуникаций с telegram
    "telegram": {
        "token": "telegram-bot-token"
    },

    // Настройки для сервера-брокера сообщений
    "redis": {
        // Значение по-умолчанию localhost
        "server": "localhost",
        // Значение по-умолчанию 6379
        "port": 6379,
        // Значения по-умолчанию нет, оно должно быть задано и совпадать с настройками aleesa-telegram-misc
        // Это канал общения с backend-приложениями
        "channel": "misc",
        // Значения по-умолчанию нет, оно должно быть задано и совпадать с настройками aleesa-telegram-misc
        // Это канал,в который отвечают backend-приложения
        "my_channel": "telegram"
    },

    // Значение по-умолчанию info
    "loglevel": "notice",
    // Значение по-умолчанию - пустая строка, в этом случае пишется на stdout
    "log": "/var/log/aleesa-telegram-bot/debug.log",
    // Значения по-умолчанию нет, должно быть задано и совпадать с настройками aleesa-telegram-misc
    // Это символ, с которого начинается команда
    "csign": "!",
    // Значение по-умолчанию 5
    // Параметр нужен для разрыва бесконечных циклов пересылки
    "forwards_max": 5,
    // Значения по-умолчанию нет, должно быть задано
    // Здесь хранятся динамические настройки приложения. Всё что связано с командой !admin
    "data_dir": "data"
}
